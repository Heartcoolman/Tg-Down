api:
  id: 0  # 你的API ID
  hash: ""  # 你的API Hash
  phone: ""  # 你的手机号

# 注：chunk_size / max_workers / rate_limit.* 已在 v2.0 移除（TDLib 自管分片/并行度/限流）
download:
  path: "./downloads"  # 下载路径
  max_concurrent: 5    # 同时下载的文件数
  batch_size: 100      # 每批拉取的历史消息数
  partition_size: 100  # 历史下载在途媒体上限（扫描最多领先下载的数量）
  disable_classify_by_type: false  # 按媒体类型归档默认开启；设为 true 可恢复旧版扁平目录布局

chat:
  target_id: 0  # 目标群组ID (可选，留空则运行时交互选择)

log:
  level: "info"  # 日志级别: debug, info, warn, error

session:
  dir: "./sessions"  # 会话文件保存目录

# 重试机制配置
retry:
  max_retries: 3       # 最大重试次数
  base_delay: 1        # 基础延迟时间 (秒)
  max_delay: 30        # 最大延迟时间 (秒)

# 任务队列配置
queue:
  max_concurrent_tasks: 1  # 同时运行的历史下载任务数（监控任务不占用此配额，独立运行）
  auto_retry: 2            # 任务失败后自动重试次数（0 关闭；重试沿用同一任务并从断点续扫）

# 持久化存储配置
store:
  path: "./tg-down.db"  # SQLite 数据库文件路径
