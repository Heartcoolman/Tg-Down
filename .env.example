# Telegram API配置
API_ID=your_api_id
API_HASH=your_api_hash
PHONE=your_phone_number

# 下载配置（CHUNK_SIZE/MAX_WORKERS 已在 v2.0 移除，TDLib 自管分片与并行度）
DOWNLOAD_PATH=./downloads
MAX_CONCURRENT_DOWNLOADS=5   # 同时下载的文件数
BATCH_SIZE=100               # 每批拉取的历史消息数

# 群组配置 (可选，如果不设置会提示选择)
TARGET_CHAT_ID=

# 日志配置
LOG_LEVEL=info

# 会话配置
SESSION_DIR=./sessions
